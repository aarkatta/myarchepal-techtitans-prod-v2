# Firebase Configuration - Web SDK
# These are PUBLIC and safe to commit (Firebase client config)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Backend API Configuration
# Point to your backend API (Python FastAPI server)
VITE_BACKEND_API_URL=http://localhost:8000

# Setup Instructions:
# 1. Copy this file to .env.local
# 2. Replace the placeholder values with your actual credentials
# 3. NEVER commit .env.local to git (it's in .gitignore)
# 4. Configure Azure OpenAI credentials in backend/.env (see backend/.env.example)
