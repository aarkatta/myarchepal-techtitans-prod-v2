rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is an archaeologist (legacy)
    function isArchaeologist() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/archaeologists/$(request.auth.uid));
    }

    // ========================================================================
    // MULTI-TENANT RBAC HELPER FUNCTIONS
    // ========================================================================

    // Get the current user's document from the users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if user exists in the new users collection
    function isUser() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Check if user is a Super Admin (global access)
    function isSuperAdmin() {
      return isUser() && getUserData().role == 'SUPER_ADMIN';
    }

    // Check if user is an Org Admin
    function isOrgAdmin() {
      return isUser() && getUserData().role == 'ORG_ADMIN';
    }

    // Check if user is any kind of admin
    function isAnyAdmin() {
      return isUser() && (getUserData().role == 'SUPER_ADMIN' || getUserData().role == 'ORG_ADMIN');
    }

    // Check if user is an org member (MEMBER role)
    function isOrgMember() {
      return isUser() && getUserData().role == 'MEMBER';
    }

    // Check if user belongs to a specific organization
    function belongsToOrg(orgId) {
      return isUser() && getUserData().organizationId == orgId;
    }

    // Check if user can access an organization (same org or super admin)
    function canAccessOrg(orgId) {
      return isSuperAdmin() || belongsToOrg(orgId);
    }

    // ========================================================================
    // CONTENT COLLECTIONS (Public read)
    // ========================================================================

    // Sites Collection - Public read, archaeologist/member/admin write
    match /Sites/{siteId} {
      allow read: if true;
      allow create, update, delete: if isArchaeologist() || isAnyAdmin() || isOrgMember();
      // Admins can update site assignment fields (linkedTemplateId, assignedConsultantId, submissionStatus, etc.)
      allow update: if request.auth != null && isAnyAdmin();
      // Assigned consultant (MEMBER) can update submissionStatus only
      allow update: if request.auth != null
                     && isUser()
                     && getUserData().role == 'MEMBER'
                     && resource.data.assignedConsultantId == request.auth.uid
                     && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['submissionStatus', 'updatedAt']);
      // MEMBER self-assigning during upload filled form wizard — can set link + assignment fields
      // on a site with no current assignee OR already assigned to them.
      // Must set assignedConsultantId to their own uid only.
      allow update: if request.auth != null
                     && isUser()
                     && getUserData().role == 'MEMBER'
                     && (resource.data.get('assignedConsultantId', '') == ''
                         || resource.data.assignedConsultantId == request.auth.uid)
                     && request.resource.data.assignedConsultantId == request.auth.uid
                     && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['linkedTemplateId', 'assignedConsultantId', 'assignedConsultantEmail', 'submissionStatus', 'updatedAt']);
    }

    // Articles Collection - Public read, archaeologist/member/admin write
    match /Articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if isArchaeologist() || isAnyAdmin() || isOrgMember();
    }

    // Events Collection - Public read, archaeologist/member/admin write
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isArchaeologist() || isAnyAdmin() || isOrgMember();
    }

    // Artifacts Collection - Public read, archaeologist/member/admin write
    match /Artifacts/{artifactId} {
      allow read: if true;
      allow create, update, delete: if isArchaeologist() || isAnyAdmin() || isOrgMember();
      // PURCHASE RULE: Allow anyone to reduce quantity for purchases
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity', 'updatedAt']) &&
                      resource.data.forSale == true &&
                      request.resource.data.quantity < resource.data.quantity;
    }

    // Merchandise Collection - Public read, authenticated users can create/update
    match /Merchandise/{merchandiseId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
      // PURCHASE RULE: Allow anyone to reduce quantity for purchases
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity', 'updatedAt']) &&
                      request.resource.data.quantity < resource.data.quantity;
      allow update: if request.auth != null;
    }

    // Help Collection - Public read, admin write (help videos shown on Help page)
    match /Help/{helpId} {
      allow read: if true;
      allow create, update, delete: if isAnyAdmin();
    }

    // Archaeologists Collection - Manage archaeologist roles (legacy)
    match /archaeologists/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // DigitalDiary Collection - Public read, user can only write their own entries
    match /DigitalDiary/{digitaldiaryId} {
      allow read: if true;
      allow create: if request.auth != null
                     && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                             && resource.data.userId == request.auth.uid;
    }

    // DropdownOptions Collection - Predefined dropdown values
    match /DropdownOptions/{docId} {
      allow read: if true;
      allow create, update: if isArchaeologist();
      allow delete: if false;
    }

    // Feedback Collection - Users submit feedback
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ========================================================================
    // MULTI-TENANT ORGANIZATION COLLECTIONS
    // ========================================================================

    // Organizations Collection
    match /organizations/{orgId} {
      // Anyone can read organizations (public)
      allow read: if true;

      // Anyone can create organizations during bootstrap
      allow create: if true;

      // Anyone authenticated can update organizations
      allow update: if request.auth != null;

      // Anyone authenticated can delete (but not system orgs)
      allow delete: if request.auth != null && orgId != 'root-org' && orgId != 'default-org';
    }

    // Users Collection (Multi-tenant)
    match /users/{userId} {
      // Anyone can read users (public for now)
      allow read: if true;

      // Anyone can create users during bootstrap
      allow create: if true;

      // Anyone authenticated can update users
      allow update: if request.auth != null;

      // Anyone authenticated can delete users
      allow delete: if request.auth != null;
    }

    // Inactive Users Collection (soft-deleted users)
    match /users_inactive/{userId} {
      // Only admins can read inactive users
      allow read: if request.auth != null && isAnyAdmin();

      // Admins can create (move users to inactive)
      allow create: if request.auth != null && isAnyAdmin();

      // Only Super Admins can update or restore
      allow update: if request.auth != null && isSuperAdmin();

      // Only Super Admins can permanently delete
      allow delete: if request.auth != null && isSuperAdmin();
    }

    // Roles Collection - System roles definition
    match /roles/{roleId} {
      // Anyone can read roles (public)
      allow read: if true;

      // Anyone can create roles during bootstrap (restrict later if needed)
      allow create: if true;

      // Anyone authenticated can update roles for now
      allow update: if request.auth != null;

      // No deletion of roles
      allow delete: if false;
    }

    // User Roles Collection - Maps users to roles in organizations
    match /user_roles/{mappingId} {
      // Anyone can read user_roles (needed for role checks)
      allow read: if true;

      // Anyone can create user_roles during bootstrap
      allow create: if true;

      // Anyone authenticated can update user_roles
      allow update: if request.auth != null;

      // Anyone authenticated can delete role mappings
      allow delete: if request.auth != null;
    }

    // Teams Collection
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (!isUser() || isAnyAdmin());
      allow update, delete: if request.auth != null && (!isUser() || isAnyAdmin());
    }

    // Team Members Collection
    match /teamMembers/{memberId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && (!isUser() || isAnyAdmin());
    }

    // Invitations Collection
    // Note: Read is public because unauthenticated users need to validate invitation tokens
    // The token itself acts as the security key
    match /invitations/{inviteId} {
      allow read: if true;
      allow create: if request.auth != null && (!isUser() || isAnyAdmin());
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (!isUser() || isAnyAdmin());
    }

    // ========================================================================
    // CHAT SYSTEM RULES
    // ========================================================================

    function isGroupMember(groupId) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/GroupMemberships/$(groupId + '_' + request.auth.uid));
    }

    function isRoomMember(roomId) {
      return request.auth != null &&
             exists(/databases/$(database)/documents/RoomMemberships/$(roomId + '_' + request.auth.uid));
    }

    function getRoomRole(roomId) {
      return get(/databases/$(database)/documents/RoomMemberships/$(roomId + '_' + request.auth.uid)).data.role;
    }

    function isRoomAdmin(roomId) {
      return isRoomMember(roomId) && (getRoomRole(roomId) == 'admin' || getRoomRole(roomId) == 'sub-admin');
    }

    match /ChatGroups/{groupId} {
      allow create: if request.auth != null;
      allow read: if isGroupMember(groupId);
      allow update, delete: if isGroupMember(groupId);
    }

    match /GroupMemberships/{membershipId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    match /ChatRooms/{roomId} {
      allow create: if request.auth != null;
      allow read: if isRoomMember(roomId);
      allow update, delete: if isRoomMember(roomId);
    }

    match /RoomMemberships/{membershipId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    match /Messages/{messageId} {
      allow read: if request.auth != null && isRoomMember(resource.data.roomId);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (request.resource.data.userId == request.auth.uid || isRoomMember(resource.data.roomId));
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isRoomMember(resource.data.roomId));
    }

    // ========================================================================
    // SITE TEMPLATES — ORG_ADMIN and MEMBER manage; all org members read all
    // ========================================================================

    match /siteTemplates/{templateId} {
      // System default templates (orgId == 'SYSTEM') are readable by any authenticated user
      // Any org member (admin or member) in the same org can read all templates
      allow read: if (request.auth != null && resource.data.orgId == 'SYSTEM')
                   || (canAccessOrg(resource.data.orgId) && isAnyAdmin())
                   || (isOrgMember() && getUserData().organizationId == resource.data.orgId);
      // ORG_ADMIN, SUPER_ADMIN, or MEMBER in same org can create (system templates blocked by orgId check)
      allow create: if request.auth != null
                    && (isAnyAdmin() || isOrgMember())
                    && request.resource.data.orgId == getUserData().organizationId;
      // System templates (orgId == 'SYSTEM') cannot be updated or deleted by any frontend user
      allow update, delete: if request.auth != null
                    && (isAnyAdmin() || isOrgMember())
                    && resource.data.orgId == getUserData().organizationId
                    && resource.data.orgId != 'SYSTEM';

      match /fields/{fieldId} {
        allow read: if request.auth != null
                     && (get(/databases/$(database)/documents/siteTemplates/$(templateId)).data.orgId == 'SYSTEM'
                         || canAccessOrg(get(/databases/$(database)/documents/siteTemplates/$(templateId)).data.orgId)
                         || (isOrgMember()
                             && getUserData().organizationId == get(/databases/$(database)/documents/siteTemplates/$(templateId)).data.orgId));
        allow write: if request.auth != null
                      && (isAnyAdmin() || isOrgMember())
                      && getUserData().organizationId == get(/databases/$(database)/documents/siteTemplates/$(templateId)).data.orgId;
      }
      match /sections/{sectionId} {
        allow read: if request.auth != null
                     && (get(/databases/$(database)/documents/siteTemplates/$(templateId)).data.orgId == 'SYSTEM'
                         || canAccessOrg(get(/databases/$(database)/documents/siteTemplates/$(templateId)).data.orgId)
                         || (isOrgMember()
                             && getUserData().organizationId == get(/databases/$(database)/documents/siteTemplates/$(templateId)).data.orgId));
        allow write: if request.auth != null
                      && (isAnyAdmin() || isOrgMember())
                      && getUserData().organizationId == get(/databases/$(database)/documents/siteTemplates/$(templateId)).data.orgId;
      }
    }

    // ========================================================================
    // SITE SUBMISSIONS — subcollection of existing Sites collection
    // ========================================================================

    match /Sites/{siteId}/submissions/{submissionId} {
      // ORG_ADMIN reads all submissions for their org's sites
      // MEMBER reads only their own submission
      allow read: if request.auth != null
                   && (isAnyAdmin()
                       || (isUser() && getUserData().role == 'MEMBER'
                           && resource.data.consultantId == request.auth.uid));
      // Assigned consultant (MEMBER or ORG_ADMIN) can create a submission
      allow create: if request.auth != null
                     && (isAnyAdmin() || (isUser() && getUserData().role == 'MEMBER'))
                     && request.resource.data.consultantId == request.auth.uid;
      // MEMBER can update only their own draft; ORG_ADMIN can update any (for protected fields)
      allow update: if request.auth != null
                     && (isAnyAdmin()
                         || (isUser() && getUserData().role == 'MEMBER'
                             && resource.data.consultantId == request.auth.uid
                             && resource.data.isDraft == true));
    }

    // ========================================================================
    // BOOTH BATTLE — public iframe-embedded scoring for org vD4x5sGreTsscAp66FgA
    // Submissions are write-once; the Cloud Function trigger computes scores
    // and writes derived state to boothBattleScores. Clients can only CREATE
    // a pending submission; no client may write boothBattleScores directly.
    // ========================================================================

    match /boothBattleSubmissions/{submissionId} {
      allow read: if true;
      allow create: if request.resource.data.orgId == 'vD4x5sGreTsscAp66FgA'
                     && request.resource.data.status == 'pending'
                     && request.resource.data.submittedKeywords is list
                     && request.resource.data.submittedKeywords.size() == 5
                     && request.resource.data.visitorName is string
                     && request.resource.data.visitorName.size() > 0
                     && request.resource.data.visitorName.size() <= 80
                     && request.resource.data.siteId is string
                     && request.resource.data.siteId.size() > 0
                     && !('score' in request.resource.data)
                     && !('matches' in request.resource.data)
                     && !('previousBestScore' in request.resource.data)
                     && !('currentBestScore' in request.resource.data)
                     && !('isNewBest' in request.resource.data)
                     && !('processedAt' in request.resource.data)
                     && !('rejectionReason' in request.resource.data);
      allow update, delete: if false;
    }

    match /boothBattleScores/{scoreId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
